{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    }
  ],
  "rewrites": [
    { "source": "/(google.*\\.html|sitemap\\.xml|robots\\.txt)", "destination": "/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
